{
  "name": "fullcircle-research",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm -r run build",
    "era:download": "pnpm --filter @fullcircle/era run download",
    "era:process": "pnpm --filter @fullcircle/era run process",
    "era:download-and-process": "pnpm --filter @fullcircle/era run download-and-process",
    "era:upload": "pnpm --filter @fullcircle/era run upload",
    "era:upload-pot": "pnpm --filter @fullcircle/era run upload-pot",
    "era:state-extract": "pnpm --filter @fullcircle/era run state-extract",
    "era:upload-sqlite": "pnpm --filter @fullcircle/era run upload-sqlite",
    "era:feed-diag": "pnpm --filter @fullcircle/era run feed-diag",
    "rpc:dev": "pnpm --filter @fullcircle/rpc run dev",
    "rpc:start": "pnpm --filter @fullcircle/rpc run start",
    "demo:dev": "pnpm --filter @fullcircle/demo run dev",
    "demo:build": "pnpm --filter @fullcircle/demo run build",
    "explorer:dev": "pnpm --filter @fullcircle/explorer run dev",
    "explorer:build": "pnpm --filter @fullcircle/explorer run build",
    "explorer:publish-to-swarm": "pnpm --filter @fullcircle/explorer run publish-to-swarm",
    "lint": "pnpm -r --if-present run lint",
    "format": "pnpm -r --if-present run format",
    "knip": "pnpm -r --if-present run knip",
    "check:all": "pnpm -r --if-present run check:all",
    "bee:start": "docker compose -f docker/compose.yml up -d",
    "bee:start:workers": "docker/scripts/workers-up.sh",
    "bee:stop": "docker compose -f docker/compose.yml --profile workers down",
    "bee:logs": "docker compose -f docker/compose.yml logs -f queen",
    "bee:fresh": "docker/scripts/fresh.sh",
    "bee:stamp": "docker/scripts/buy-stamp.sh",
    "proxy:start": "pnpm --filter @fullcircle/proxy run start",
    "proxy:dev": "pnpm --filter @fullcircle/proxy run dev",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
