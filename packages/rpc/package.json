{
  "name": "@fullcircle/rpc",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./methods": "./src/methods.ts"
  },
  "scripts": {
    "dev": "tsx watch src/bin.ts",
    "start": "tsx src/bin.ts",
    "check": "tsc --noEmit",
    "typecheck": "pnpm check",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write . && eslint . --fix",
    "knip": "knip",
    "check:all": "pnpm lint && pnpm check && pnpm knip"
  },
  "dependencies": {
    "@ethereumjs/rlp": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "knip": "^6.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "viem": "^2.48.1",
    "vitest": "^4.1.4"
  }
}
