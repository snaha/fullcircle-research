{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "lib": ["ES2022"],
    "noEmit": true
  },
  "include": ["src/**/*", "test/**/*", "vitest.config.ts"]
}
