{
  "name": "@fullcircle/era",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./bundle": "./src/bundle.ts"
  },
  "scripts": {
    "download": "tsx src/download.ts",
    "process": "tsx src/process.ts",
    "download-and-process": "tsx src/download-and-process.ts",
    "upload": "tsx src/upload.ts",
    "check": "tsc --noEmit",
    "typecheck": "pnpm check",
    "build": "tsc",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write . && eslint . --fix",
    "knip": "knip",
    "check:all": "pnpm lint && pnpm check && pnpm knip"
  },
  "dependencies": {
    "@ethereumjs/rlp": "^5.0.2",
    "@ethersphere/bee-js": "^8.0.0",
    "@noble/hashes": "^1.4.0",
    "mantaray-js": "^1.0.3",
    "snappyjs": "^0.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "knip": "^6.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
