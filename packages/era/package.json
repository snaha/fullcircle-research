{
  "name": "@fullcircle/era",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./bundle": "./src/bundle.ts",
    "./feed-topics": "./src/feed-topics.ts"
  },
  "scripts": {
    "download": "tsx src/download.ts",
    "process": "tsx src/process.ts",
    "download-and-process": "tsx src/download-and-process.ts",
    "upload": "tsx src/upload.ts",
    "upload-pot": "tsx src/upload-pot.ts",
    "state-extract": "tsx src/state-extract.ts",
    "upload-sqlite": "tsx src/upload-sqlite.ts",
    "feed-diag": "tsx src/feed-diag.ts",
    "check": "tsc --noEmit",
    "typecheck": "pnpm check",
    "build": "tsc",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write . && eslint . --fix",
    "knip": "knip",
    "check:all": "pnpm lint && pnpm check && pnpm knip"
  },
  "dependencies": {
    "@ethereumjs/block": "10.1.1",
    "@ethereumjs/blockchain": "10.1.1",
    "@ethereumjs/common": "10.1.1",
    "@ethereumjs/genesis": "10.1.1",
    "@ethereumjs/mpt": "10.1.1",
    "@ethereumjs/rlp": "^5.0.2",
    "@ethereumjs/statemanager": "10.1.1",
    "@ethereumjs/tx": "10.1.1",
    "@ethereumjs/util": "10.1.1",
    "@ethereumjs/vm": "10.1.1",
    "@ethersphere/bee-js": "^11.1.1",
    "@noble/curves": "^1.9.1",
    "@noble/hashes": "^1.4.0",
    "better-sqlite3": "^11.9.1",
    "mantaray-js": "^1.0.3",
    "snappyjs": "^0.7.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "knip": "^6.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
